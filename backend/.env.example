PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d

# Nodemailer / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_app_password
FROM_NAME=InstantSeva
FROM_EMAIL=noreply@hyperlocal.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Maps (Optional for now)
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Location search proxy
NOMINATIM_USER_AGENT=InstantSeva/1.0 (your_email@example.com)
GEOCODER_COUNTRY_CODES=in
